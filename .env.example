# Path to Claude Code session directory
CLAUDE_DIR=~/.claude

# Express server port
SERVER_PORT=3001

# Time (ms) since last message to consider a session "active" (default: 60000 = 1min)
ACTIVE_THRESHOLD_MS=60000

# LLM provider for workflow analysis: anthropic | openai | gemini
ANALYSIS_PROVIDER=anthropic

# Override the default model per provider (leave empty for provider default)
#   anthropic → claude-haiku-4-5-20251001
#   openai    → gpt-4o-mini
#   gemini    → gemini-2.0-flash
ANALYSIS_MODEL=

# Debounce (ms) before triggering LLM workflow re-analysis after new messages (default: 3000)
# Lower = more responsive but higher API cost; higher = cheaper but slower refresh
VITE_ANALYSIS_DEBOUNCE_MS=3000

# Provider API keys (only the selected provider's key is required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
